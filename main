from flask import Flask, jsonify
import requests
from mangum import Mangum

app = Flask(__name__)

# مقادیر دقیق و اختصاصی شما که به صورت هاردکد تنظیم شده‌اند
TELEGRAM_TOKEN = "8740696167:AAHSCQete8X7EMDVcFovV9RBjaJnMy-KEJA"
CHAT_ID = "391754544"

@app.route("/")
def send_telegram_message():
    try:
        # آدرس استاندارد API تلگرام برای ارسال پیام
        url = f"https://api.telegram.org/bot{TELEGRAM_TOKEN}/sendMessage"
        
        payload = {
            "chat_id": CHAT_ID,
            "text": "سلام! پروژه شما با موفقیت و به صورت کامل روی پلتفرم نتلیفای مستقر و اجرا شد. ✅"
        }
        
        # ارسال درخواست POST به تلگرام
        response = requests.post(url, json=payload)
        
        if response.status_code == 200:
            return jsonify({
                "status": "success", 
                "message": "پیام با موفقیت به تلگرام ارسال شد!"
            }), 200
        else:
            return jsonify({
                "status": "error", 
                "details": response.json()
            }), 400
            
    except Exception as e:
        return jsonify({
            "status": "exception", 
            "error": str(e)
        }), 500

# لایه واسط مانگوم برای هماهنگی با ساختار بدون سرور نتلیفای
handler = Mangum(app)
